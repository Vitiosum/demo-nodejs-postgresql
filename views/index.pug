extends layout

block content
  div.container
    div.header
      div.badge
        span.dot
        | Live on Clever Cloud
      h1
        span.node Node.js
        |  +
        span.pg PostgreSQL
      p.subtitle A persistent key-value store powered by Express and PostgreSQL
      a.cc-logo-link(href="https://www.clever-cloud.com" target="_blank" rel="noopener noreferrer")
        img.cc-logo-img(
          src="https://assets.clever-cloud.com/brand/Clever_Cloud-logo_white.svg"
          alt="Clever Cloud"
          onerror="this.style.display='none';this.nextElementSibling.style.display='inline-flex'"
        )
        span.cc-logo-fallback(style="display:none; align-items:center; gap:8px; background:rgba(34,197,94,0.12); border:1px solid rgba(34,197,94,0.25); border-radius:99px; color:#86efac; font-size:13px; font-weight:600; padding:6px 14px;")
          svg(width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#22c55e" stroke-width="2")
            path(d="M18 10h-1.26A8 8 0 1 0 9 20h9a5 5 0 0 0 0-10z")
          | Clever Cloud

    div.card
      div.card-title Add a value
      form#createForm(method="post" action="/values")
        div.input-row
          input.input-field(
            type="text"
            name="value"
            id="value"
            placeholder="Enter a value…"
            maxlength="32"
            autocomplete="off"
          )
          button.btn-submit(type="submit" id="create")
            span.spinner#spinner
            span#btn-text Add

    div.card
      div.card-title
        | Stored values
        span#count(style="margin-left:8px; font-weight:400; color:#475569")
          if values && Object.keys(values).length > 0
            | (#{Object.keys(values).length})
      if values && Object.keys(values).length > 0
        ul.values-list#list
          each val, id in values
            li.value-item(id=id)
              div
                div.value-text= val
                div.value-id ##{id}
              button.btn-delete(onclick=`deleteItem(${id})`) Delete
      else
        div#list
        div.empty-state
          div.empty-icon 🗃️
          div No values yet — add one above

    footer.footer
      div.footer-links
        a.footer-link.cc(href="https://www.clever-cloud.com" target="_blank" rel="noopener noreferrer")
          svg(width="13" height="13" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2")
            path(d="M18 10h-1.26A8 8 0 1 0 9 20h9a5 5 0 0 0 0-10z")
          | clever-cloud.com
        a.footer-link.li(href="https://www.linkedin.com/company/clever-cloud/" target="_blank" rel="noopener noreferrer")
          svg(width="13" height="13" viewBox="0 0 24 24" fill="currentColor")
            path(d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6zM2 9h4v12H2z")
            circle(cx="4" cy="4" r="2")
          | LinkedIn
        a.footer-link(href="https://developers.clever-cloud.com/doc/applications/javascript/nodejs/" target="_blank" rel="noopener noreferrer")
          svg(width="13" height="13" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2")
            path(d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20")
            path(d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z")
          | Node.js on CC
        a.footer-link(href="https://developers.clever-cloud.com/doc/addons/postgresql/" target="_blank" rel="noopener noreferrer")
          svg(width="13" height="13" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2")
            ellipse(cx="12" cy="5" rx="9" ry="3")
            path(d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3")
            path(d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5")
          | PostgreSQL on CC
        a.footer-link(href="https://expressjs.com" target="_blank" rel="noopener noreferrer")
          svg(width="13" height="13" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2")
            polyline(points="16 18 22 12 16 6")
            polyline(points="8 6 2 12 8 18")
          | Express.js
      p.footer-copy Open source demo · Deployed on Clever Cloud
